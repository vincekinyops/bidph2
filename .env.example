# Web app (copy to web/.env.local)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
# Local dev only — sign in with this email to access /admin (never set in production)
VITE_DEV_ADMIN_EMAIL=you@example.com

# Server-only (webhook / service RPCs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status
PAYMONGO_WEBHOOK_SECRET=
